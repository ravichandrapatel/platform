# GitHub Actions Runner (ARC-style) on UBI9, rootless Podman/Buildah only.
# Build with: buildah build (or podman build). No other container runtime references.
# Runner, k8s hooks, and tools under /home/runner. Runs as non-root (UID 1001, GID 123).
#
# Rootless Podman/Buildah tuning follows Red Hat guidance for OpenShift:
#   https://www.redhat.com/en/blog/rootless-podman-jenkins-openshift
# - Buildah ENV (chroot isolation, vfs); newuidmap/newgidmap sticky bit removed + setcap;
# - Loosened permissions on dirs used by build tools (alternatives, jvm, etc.).
#
# Validated for OpenShift SCC overlays/rosadev/scc-github-arc.yaml:
#   - runAsUser MustRunAs 1001 -> image user "runner" UID 1001
#   - fsGroup/supplementalGroups 123 -> image group "runner" GID 123; pod uses runAsGroup/fsGroup 123
#   - Pod securityContext runAsUser: 1001, runAsGroup: 123, fsGroup: 123, runAsNonRoot: true

# ------------------------------------------------------------------------------
# Stage 1: Runner assets (UBI9; runner binary only, no Ubuntu)
# ------------------------------------------------------------------------------
FROM registry.access.redhat.com/ubi9/ubi AS build

ARG TARGETPLATFORM
ARG RUNNER_VERSION=2.321.0
ARG RUNNER_CONTAINER_HOOKS_VERSION=0.8.1

# Update base for compliance; do not change RUNNER_VERSION / RUNNER_CONTAINER_HOOKS_VERSION
# --allowerasing: UBI9 has curl-minimal; allow replacing with curl to satisfy dependency.
RUN dnf update -y --nodocs --setopt=install_weak_deps=False \
    && dnf install -y --nodocs --setopt=install_weak_deps=False --allowerasing curl unzip ca-certificates \
    && dnf clean all

RUN test -n "$TARGETPLATFORM" || (echo "TARGETPLATFORM must be set" && false)

WORKDIR /runner-assets

RUN export ARCH=$(echo ${TARGETPLATFORM} | cut -d / -f2) \
    && if [ "$ARCH" = "amd64" ] || [ "$ARCH" = "x86_64" ] || [ "$ARCH" = "i386" ]; then export ARCH=x64; fi \
    && if [ "$ARCH" = "arm64" ]; then export ARCH=arm64; fi \
    && curl -fLo runner.tar.gz "https://github.com/actions/runner/releases/download/v${RUNNER_VERSION}/actions-runner-linux-${ARCH}-${RUNNER_VERSION}.tar.gz" \
    && tar xzf runner.tar.gz && rm runner.tar.gz

# k8s hooks (not k8s-novolume) under /home/runner/k8s
RUN curl -fLo k8s-hooks.zip "https://github.com/actions/runner-container-hooks/releases/download/v${RUNNER_CONTAINER_HOOKS_VERSION}/actions-runner-hooks-k8s-${RUNNER_CONTAINER_HOOKS_VERSION}.zip" \
    && unzip -q k8s-hooks.zip -d ./k8s && rm k8s-hooks.zip

# ------------------------------------------------------------------------------
# Stage 2: UBI9 + rootless Podman/Buildah, non-root runner (1001:123)
# ------------------------------------------------------------------------------
FROM registry.access.redhat.com/ubi9/ubi

ARG TARGETPLATFORM=linux/amd64
ARG RUNNER_VERSION=2.321.0
ARG DUMB_INIT_VERSION=1.2.5
ARG RUNNER_UID=1001
ARG RUNNER_GID=123
ARG SUBUID_COUNT=100000

ENV RUNNER_HOME=/home/runner
ENV RUNNER_MANUALLY_TRAP_SIG=1
ENV ACTIONS_RUNNER_PRINT_LOG_TO_STDOUT=1
ENV ImageOS=linux
ENV PODMAN_USERNS=keep-id
ENV HOME=/home/runner
# Use vfs storage so rootless Podman works without /dev/fuse (e.g. in OpenShift pods).
# Override with CONTAINERS_STORAGE_DRIVER=overlay if /dev/fuse is available and preferred.
ENV CONTAINERS_STORAGE_DRIVER=vfs
# Rootless Buildah/Podman: no user namespace wrap, chroot isolation, vfs (per Red Hat OpenShift blog).
ENV _BUILDAH_STARTED_IN_USERNS="" \
    BUILDAH_ISOLATION=chroot \
    STORAGE_DRIVER=vfs

# Update base for compliance; do not change RUNNER_VERSION. Exclude container-selinux for rootless (blog).
# --allowerasing: UBI9 curl-minimal conflicts with curl; allow replacement.
RUN dnf update -y --nodocs --setopt=install_weak_deps=False \
    && dnf install -y --nodocs --setopt=install_weak_deps=False --allowerasing \
        git sudo curl jq unzip ca-certificates shadow-utils libcap \
        podman buildah skopeo crun fuse-overlayfs slirp4netns \
        --exclude=container-selinux \
    && dnf clean all

# dumb-init for signal handling
RUN export ARCH=$(echo ${TARGETPLATFORM} | cut -d / -f2) \
    && if [ "$ARCH" = "arm64" ]; then ARCH=aarch64; fi \
    && if [ "$ARCH" = "amd64" ] || [ "$ARCH" = "x86_64" ]; then ARCH=x86_64; fi \
    && curl -fLo /usr/bin/dumb-init "https://github.com/Yelp/dumb-init/releases/download/v${DUMB_INIT_VERSION}/dumb-init_${DUMB_INIT_VERSION}_${ARCH}" \
    && chmod +x /usr/bin/dumb-init

# Rootless Podman/Buildah: fix newuidmap/newgidmap (sticky bit + capabilities). Required for user namespace
# mapping in OpenShift; see https://www.redhat.com/en/blog/rootless-podman-jenkins-openshift
RUN chmod u-s /usr/bin/newuidmap /usr/bin/newgidmap 2>/dev/null || true \
    && /usr/sbin/setcap cap_setuid+eip /usr/bin/newuidmap 2>/dev/null || true \
    && /usr/sbin/setcap cap_setgid+eip /usr/bin/newgidmap 2>/dev/null || true

# Loosen permissions on dirs used by build tools (Java, alternatives, etc.) so rootless builds can write
RUN mkdir -p /var/lib/origin \
    && chmod 775 /var/lib/origin \
    && chmod -R 775 /etc/alternatives /var/lib/alternatives 2>/dev/null || true \
    && chmod -R 775 /usr/lib/jvm 2>/dev/null || true \
    && chmod 775 /usr/share/man/man1 2>/dev/null || true

# Non-root user/group to match OpenShift SCC (uid 1001, gid 123); sudo so runner avoids forbidden errors
RUN groupadd -r -g ${RUNNER_GID} runner \
    && useradd -r -u ${RUNNER_UID} -g runner -m -s /bin/bash -d /home/runner runner \
    && usermod -aG wheel runner \
    && echo '%wheel ALL=(ALL:ALL) NOPASSWD:ALL' > /etc/sudoers.d/wheel \
    && chmod 440 /etc/sudoers.d/wheel

# Subordinate UID/GID for rootless Podman/Buildah
RUN echo "runner:100000:${SUBUID_COUNT}" >> /etc/subuid \
    && echo "runner:100000:${SUBUID_COUNT}" >> /etc/subgid

# ARC scripts
COPY runner/entrypoint.sh runner/startup.sh runner/logger.sh runner/graceful-stop.sh runner/update-status /usr/bin/
RUN chmod +x /usr/bin/entrypoint.sh /usr/bin/startup.sh /usr/bin/update-status

# ARC hooks
COPY runner/hooks/job-started.sh runner/hooks/job-completed.sh /etc/arc/hooks/
COPY runner/hooks/job-started.d runner/hooks/job-completed.d /etc/arc/hooks/
RUN chmod +x /etc/arc/hooks/job-started.sh /etc/arc/hooks/job-completed.sh \
    && for f in /etc/arc/hooks/job-started.d/* /etc/arc/hooks/job-completed.d/*; do [ -f "$$f" ] && chmod +x "$$f"; done

# Runner + k8s hooks under /home/runner, owned by runner:runner (1001:123)
RUN mkdir -p /home/runner
COPY --from=build /runner-assets /home/runner
RUN chown -R runner:runner /home/runner

# Rootless Podman: force vfs storage (no FUSE) and disable default_sysctls (no ping_group_range)
RUN mkdir -p /home/runner/.config/containers
COPY runner/containers/storage.conf runner/containers/containers.conf /home/runner/.config/containers/
RUN chown -R runner:runner /home/runner/.config

# PAM-like env for runner process
RUN echo "PATH=/usr/bin:/bin" > /etc/environment && echo "ImageOS=${ImageOS}" >> /etc/environment

RUN mkdir -p /opt/hostedtoolcache && chown runner:runner /opt/hostedtoolcache && chmod 775 /opt/hostedtoolcache

USER runner

ENTRYPOINT ["/usr/bin/entrypoint.sh"]
