# act secrets – copy to .env and fill in. Do not commit .env.
# Pass with: ./devtools-landingzone/act/run.sh <workflow> --secret-file devtools-landingzone/act/.env

# Required for checkout and (optionally) GHCR push
GITHUB_TOKEN=

# Optional: NVD API key for OWASP Dependency-Check (avoids rate limits)
# dependency-check-nightly
# NVD_API_KEY=

# For drift-check / terraform workflows (omit for action-only local tests)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
# AWS_REGION=us-east-1

# If using GitHub App for Terraform (not typically used with act)
# TF_APP_ID=
# TF_APP_INSTALLATION_ID=
# TF_APP_PRIVATE_KEY=
